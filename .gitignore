# =============================================================================
# Deploy-AMD-Drivers-For-WindowsServer .gitignore
# =============================================================================

# ----- Script runtime artefacts (never commit) -------------------------------
# These are generated by the PowerShell scripts and contain machine-specific
# data (cert thumbprints, hardware fingerprints, etc.)
C:/AMD-Chipset-WS/
C:/AMD-Graphics-WS/
*.pfx
*.cer
*.cat
*.snk
inf_inventory.csv
inf_inventory_report.txt
chipset-AWS-*.log
graphics-AWS-*.log
m75q-*.log
x13gen1-*.log
*-prepareverify.log
*-install.log

# ----- Python tool artefacts -------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# ----- IDE / editor ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Build / package -------------------------------------------------------
build/
dist/
*.egg-info/

# ----- AMD installer downloads (large binaries, never commit) ----------------
amd_chipset_software_*.exe
whql-amd-software-*.exe
non-whql-amd-software-*.exe

# ----- Sensitive / personal --------------------------------------------------
*.key
*.pem
*.p12
*.password
secrets.json
.env
.env.local
